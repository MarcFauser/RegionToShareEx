<Window x:Class="RegionToShareEx.RecordingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RegionToShareEx"
        mc:Ignorable="d"
        WindowStyle="None" Background="Transparent" 
        AllowsTransparency="True" Topmost="True"
        ShowInTaskbar="False"
        Title="Region to Share Ex - Source Region" Height="450" Width="800">
  <Grid>
    <Border BorderThickness="{x:Static local:RecordingWindow.BorderSize}">
      <Border.BorderBrush>
        <LinearGradientBrush StartPoint="0,0" EndPoint="8,8" SpreadMethod="Repeat" MappingMode="Absolute">
          <GradientStop Offset="0" Color="{DynamicResource ThemeColor}" />
          <GradientStop Offset="0.5" Color="{DynamicResource ThemeColor}" />
          <GradientStop Offset="0.5" Color="#10000000" />
          <GradientStop Offset="1" Color="#10000000" />
        </LinearGradientBrush>
      </Border.BorderBrush>
      <Grid x:Name="ClientArea">
        <Button Width="16" Height="16"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                ToolTip="Close"
                Click="Button_Click">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border x:Name="Background" Background="Transparent">
                <Path Width="12" Height="12"
                      Data="M2,2 L10,10 M2,10 L10,2"
                      Stroke="White"
                      StrokeThickness="1.5"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Background" Property="Background" Value="#40FFFFFF" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Button.Template>
        </Button>
      </Grid>
    </Border>
  </Grid>
</Window>
